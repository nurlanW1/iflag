{
  "name": "backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:workspace-deps": "npm run build --prefix ../../packages/storage && npm run build --prefix ../../packages/watermarking",
    "build": "npm run build:workspace-deps && tsc && node scripts/copy-sql.mjs",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "import:r2": "node dist/scripts/import-r2-files.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@clerk/backend": "^3.2.13",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.1.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "otplib": "^13.4.0",
    "pg": "^8.17.2",
    "prettier": "^3.8.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "storage": "file:../../packages/storage",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "uuid": "^11.0.3",
    "watermarking": "file:../../packages/watermarking"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
