# =============================================================================
# Backend environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Core -------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Postgres / Neon connection string
DATABASE_URL=postgresql://user:password@localhost:5432/flagstock

# Frontend origin allowed by CORS (single origin or comma-list handled in code)
FRONTEND_URL=http://localhost:3000

# --- Auth (JWT) -------------------------------------------------------------
# Long, random string. Generate with: `openssl rand -hex 64`.
JWT_SECRET=replace_with_64_byte_hex_in_production

# Access token lifetime. Either seconds or a vercel/ms shorthand like `15m`, `1h`, `7d`.
JWT_EXPIRES_IN=15m

# Legacy backward-compat (still read by some routes)
SESSION_SECRET=replace_this_secret

# Minimum allowed password length on register / reset / change.
MIN_PASSWORD_LENGTH=8

# --- Email verification + password reset ------------------------------------
# How long the verify link lasts (hours).
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# How often the same user can request a new verify email (seconds).
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# How long the password reset link lasts (minutes).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- Mailer -----------------------------------------------------------------
# `console`  → log emails to stdout (default; safe for dev)
# `resend`   → POST to https://api.resend.com (set RESEND_API_KEY below)
MAIL_PROVIDER=console

# From-address used on all transactional emails.
MAIL_FROM_ADDRESS=no-reply@yourdomain.com
MAIL_FROM_NAME=Flag Stock

# Brand name shown in email templates and subjects.
APP_NAME=Flag Stock Marketplace

# Base URL where the frontend handles verify/reset pages. Used to build the
# clickable links in transactional emails. Defaults to FRONTEND_URL.
PUBLIC_FRONTEND_URL=http://localhost:3000

# Provider-specific
RESEND_API_KEY=

# --- MFA (TOTP) -------------------------------------------------------------
# The label shown in authenticator apps (Google Authenticator, Authy, etc.).
MFA_ISSUER=Flag Stock

# How long the post-password "MFA challenge" token lives (seconds).
MFA_CHALLENGE_TTL_SECONDS=300

# AES-256-GCM key for TOTP secret encryption. Backed by scrypt KDF, so any
# long random string works. REQUIRED in production — if unset, JWT_SECRET is
# used as a fallback (acceptable for dev but rotate before launch).
ENCRYPTION_KEY=

# --- Active billing provider ------------------------------------------------
# Which provider /api/billing/checkout uses for new sessions.
#   paddle        → recommended (works from Uzbekistan, MoR, global tax handling)
#   lemonsqueezy  → legacy (does not support UZ payouts)
BILLING_PROVIDER=paddle

# --- Billing: Paddle Billing ------------------------------------------------
# Sign up at https://paddle.com (live) or https://sandbox-vendors.paddle.com.
# - API key:        Dashboard → Developer Tools → API authentication
#                   (live: pdl_live_*, sandbox: pdl_sdbx_apikey_*)
# - Webhook secret: Dashboard → Developer Tools → Notifications →
#                   create endpoint → copy the signing secret
#                   (live: pdl_ntfset_*, sandbox: ntfset_*)
#
# The webhook URL to register in Paddle:
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# `sandbox` | `production` (default inferred from the API key).
# Set explicitly if you use a live key while the rest of your stack runs locally.
# PADDLE_ENVIRONMENT=sandbox

# Optional checkout success redirect.
# PADDLE_CHECKOUT_SUCCESS_URL=https://yourdomain.com/dashboard/purchases

# Default currency for one-off / generic price creation (ISO 4217).
PADDLE_DEFAULT_CURRENCY=USD

# Map your local slugs → Paddle price ids (`pri_*`).
# Same shape as the Lemon Squeezy map. Get price ids from Paddle Dashboard →
# Catalog → Prices.
# PADDLE_PRICE_MAP_JSON={"subscriptionByPlanSlug":{"weekly-premium":"pri_...","monthly-premium":"pri_..."},"oneTimeByProductSlug":{"single-flag":"pri_..."}}

# --- Billing: Lemon Squeezy (LEGACY — kept for back-compat) -----------------
# Get these from https://app.lemonsqueezy.com
#   API key:      Settings → API → "Create API key"
#   Store id:     Settings → Stores → numeric id (3-5 digits)
#   Signing key:  Settings → Webhooks → your endpoint → "Signing secret"
#
# The webhook URL to register in Lemon Squeezy:
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/lemonsqueezy
#   (Local dev with ngrok: https://YOUR-NGROK.ngrok.app/api/billing/webhook/lemonsqueezy)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_SIGNING_SECRET=

# Optional: where the customer is redirected after a successful checkout.
# Defaults to LS-hosted success page if unset.
# LEMONSQUEEZY_CHECKOUT_SUCCESS_URL=https://yourdomain.com/dashboard/purchases

# Set to "true" while the LS store is in test mode (test cards only).
LEMONSQUEEZY_TEST_MODE=true

# Maps your local plan/product slugs → LS variant ids.
# Same shape as the frontend env var, so they can be copied 1:1.
# LEMONSQUEEZY_VARIANT_MAP_JSON={"subscriptionByPlanSlug":{"weekly-premium":"123456","monthly-premium":"789012"},"oneTimeByProductSlug":{"united-states-standard":"345678"}}

# Optional alternative: leave the env empty and set `provider_variant_id`
# on each row of the `subscription_plans` table. The mapping service checks env first, DB second.

# --- Upload / Storage -------------------------------------------------------
UPLOAD_TEMP_DIR=./tmp/uploads
MAX_FILE_SIZE=524288000
CHUNK_SIZE=10485760
STORAGE_TYPE=local
STORAGE_BASE_URL=http://localhost:4000/uploads
STORAGE_BASE_PATH=./uploads

# --- Redis (Bull queue) -----------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Optional integrations --------------------------------------------------
# VIRUS_SCANNER=none   # clamav | virustotal | none
# CDN_PROVIDER=cloudflare   # cloudflare | cloudfront | none
# MFA_ISSUER=Flag Stock Admin
