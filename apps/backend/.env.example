# =============================================================================
# Backend environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Core -------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Postgres / Neon connection string
# Remote hosts: Neon URLs may include sslmode=require; backend maps require/prefer/verify-ca → verify-full (matches strict TLS today; avoids pg v9 warnings).
DATABASE_URL=postgresql://user:password@localhost:5432/flagstock

# Optional: Neon “Pooled connection” string for CLI scripts (import:r2, backfill:*).
# If unset, scripts auto-append `-pooler` to *.neon.tech hosts.
# DATABASE_POOL_URL=

# CLI scripts on Neon auto-use the serverless driver (WebSocket / port 443) when the host is *.neon.tech.
# Set false to force TCP pg only: DATABASE_USE_NEON_SERVERLESS=false
# DATABASE_USE_NEON_SERVERLESS=true
# DATABASE_USE_POOLER=false

# Frontend origin(s) for CORS — comma/semicolon-separated. Always merged with built-in:
#   https://flagswing.com, https://www.flagswing.com, http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Extra allowed origins (e.g. https://your-app.vercel.app). Comma-separated.
# ADDITIONAL_CORS_ORIGINS=

# Allow any *.vercel.app Origin when true (preview deployments).
# CORS_ALLOW_VERCEL_PREVIEWS=false

# Listen address (Railway/Docker: leave default 0.0.0.0)
# LISTEN_HOST=0.0.0.0

# --- Auth (JWT) -------------------------------------------------------------
# Long, random string. Generate with: `openssl rand -hex 64`.
JWT_SECRET=replace_with_64_byte_hex_in_production

# Access token lifetime. Either seconds or a vercel/ms shorthand like `15m`, `1h`, `7d`.
JWT_EXPIRES_IN=15m

# Legacy backward-compat (still read by some routes)
SESSION_SECRET=replace_this_secret

# Minimum allowed password length on register / reset / change.
MIN_PASSWORD_LENGTH=8

# Shared secret for Clerk → backend JWT bridge (same value on Next.js server).
# Frontend calls POST /api/auth/clerk-sync → backend POST /auth/bridge/clerk-session with header X-Internal-Bridge-Secret.
# Generate with: `openssl rand -hex 32`.
INTERNAL_AUTH_BRIDGE_SECRET=

# Clerk secret for verifying `Authorization: Bearer <session JWT>` from `getToken()`:
# — admin flag upload (`POST /api/admin/flag-files/upload`)
# — Paddle `/api/billing/checkout` when JWT cookies are not used (recommended for Clerk users on `/pricing`).
# Must match the Clerk Dashboard “Secret keys” production `CLERK_SECRET_KEY`.
CLERK_SECRET_KEY=

# Comma/semicolon-separated admin emails for Clerk bearer routes (falls back to ADMIN_EMAIL_ALLOWLIST).
ADMIN_EMAIL=

# --- Email verification + password reset ------------------------------------
# How long the verify link lasts (hours).
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# How often the same user can request a new verify email (seconds).
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# How long the password reset link lasts (minutes).
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- Mailer -----------------------------------------------------------------
# `console`  → log emails to stdout (default; safe for dev)
# `resend`   → POST to https://api.resend.com (set RESEND_API_KEY below)
MAIL_PROVIDER=console

# From-address used on all transactional emails.
MAIL_FROM_ADDRESS=no-reply@yourdomain.com
MAIL_FROM_NAME=Flag Stock

# Brand name shown in email templates and subjects.
APP_NAME=Flag Stock Marketplace

# Base URL where the frontend handles verify/reset pages. Used to build the
# clickable links in transactional emails. Defaults to FRONTEND_URL.
PUBLIC_FRONTEND_URL=http://localhost:3000

# Provider-specific
RESEND_API_KEY=

# --- MFA (TOTP) -------------------------------------------------------------
# The label shown in authenticator apps (Google Authenticator, Authy, etc.).
MFA_ISSUER=Flag Stock

# How long the post-password "MFA challenge" token lives (seconds).
MFA_CHALLENGE_TTL_SECONDS=300

# AES-256-GCM key for TOTP secret encryption. Backed by scrypt KDF, so any
# long random string works. REQUIRED in production — if unset, JWT_SECRET is
# used as a fallback (acceptable for dev but rotate before launch).
ENCRYPTION_KEY=

# --- Billing: Paddle Billing ------------------------------------------------
# Sign up at https://paddle.com (live) or https://sandbox-vendors.paddle.com.
# - API key:        Dashboard → Developer Tools → API authentication
#                   (live: pdl_live_*, sandbox: pdl_sdbx_apikey_*)
# - Webhook secret: Dashboard → Developer Tools → Notifications →
#                   create endpoint → copy the signing secret
#                   (live: pdl_ntfset_*, sandbox: ntfset_*)
#
# Webhook URL (backend):
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# `sandbox` | `production` (default inferred from the API key).
# Set explicitly if you use a live key while the rest of your stack runs locally.
# PADDLE_ENVIRONMENT=sandbox

# Checkout payment-link base (approved domain). Paddle builds checkout.url as base + ?_ptxn=txn_….
# Also set Dashboard → Checkout → Checkout settings → Default payment link (required once per account).
# PADDLE_DEFAULT_PAYMENT_LINK=https://www.flagswing.com
# Legacy alias if DEFAULT_PAYMENT_LINK unset:
# PADDLE_CHECKOUT_SUCCESS_URL=https://www.flagswing.com
# PADDLE_API_DEBUG=true

# Default currency for one-off / generic price creation (ISO 4217).
PADDLE_DEFAULT_CURRENCY=USD

# Map local slugs → Paddle price ids (`pri_*`). Catalog → Products → Prices.
# Required for /pricing checkout — copy the price id from Paddle Dashboard.
# PADDLE_PRICE_MAP_JSON={"oneTimeByProductSlug":{"flag-stock":"pri_01..."}}
# Checkout stores custom_data.product_slug + asset_group_key; webhook writes user_asset_purchases.

# Optional alternative: leave the env empty and set `provider_variant_id`
# on each row of the `subscription_plans` table. The mapping service checks env first, DB second.

# --- Upload / Storage -------------------------------------------------------
UPLOAD_TEMP_DIR=./tmp/uploads
MAX_FILE_SIZE=524288000
CHUNK_SIZE=10485760
STORAGE_TYPE=local
STORAGE_BASE_URL=http://localhost:4000/uploads
STORAGE_BASE_PATH=./uploads

# Flagswing gallery uploads — CLOUDFLARE_R2_* (also used when STORAGE_TYPE=s3 aliases below)
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=
# CLOUDFLARE_R2_PUBLIC_URL=https://cdn.yourdomain.com
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Marketplace pipeline S3/R2 (when STORAGE_TYPE=s3)
# CLOUDFLARE_ACCOUNT_ID=
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://cdn.yourdomain.com
#
# Aliases also accepted: AWS_S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION (default auto).

# --- Redis (Bull queue) -----------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Optional integrations --------------------------------------------------
# VIRUS_SCANNER=none   # clamav | virustotal | none
# CDN_PROVIDER=cloudflare   # cloudflare | cloudfront | none
# MFA_ISSUER=Flag Stock Admin
