# Admin allow-list: comma/semicolon/newline-separated Clerk emails (any linked address may access /admin).
# If unset, a built-in fallback owner address is used — set explicitly in production to override.
# Mirrors into NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST (+ first entry as NEXT_PUBLIC_ADMIN_EMAIL) in next.config.mjs.
ADMIN_EMAIL=

# Flagswing gallery (`/gallery/...`): `/api/download/[fileId]` allows bytes only when:
#   • mailbox is listed in MARKETPLACE_OWNER_DOWNLOAD_EMAILS (default: single owner Gmail at build unless you override), OR
#   • Neon `user_subscriptions` shows an active Paddle-backed period for the Clerk user, OR
#   • backend `/subscriptions/check-premium` returns true (JWT cookies from signup/login bridge — see API_URL / INTERNAL_AUTH_BRIDGE_SECRET).
# ADMIN_EMAIL grants /admin UI only — it does **not** unlock paid storefront downloads.
#
# Neon SQL (DATABASE_URL gallery DB) for subscription syncing:
#   1) neon_001_countries_and_flag_files.sql
#   2) neon_002_user_subscriptions_clerk.sql
#
# Optional overrides (otherwise derived from ADMIN_EMAIL at build).
# NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=a@x.com,b@y.com
# NEXT_PUBLIC_ADMIN_EMAIL=

# Optional: merge legacy on-disk flag_stock JPG tiles into Neon gallery list when DB has rows.
# Default off — landing + gallery prefer DB+R2 only (avoid old static previews).
# FLAG_STOCK_MERGE_WITH_DB=true

# Postgres (same Neon DATABASE_URL — required for `/api/admin/flag-files/upload` row insert)
# Neon often uses ?sslmode=require — the app normalizes remote URLs to sslmode=verify-full for Node pg v9 compatibility.
DATABASE_URL=

# --- Cloudflare R2 (server-side only — signed downloads + URL building) ---
# Match Railway/Vercel env for `country_flag_files` + `/api/download` + gallery rewires.
#
# S3 API endpoint (uploads / signed GET) — example:
#   https://f60aa12c6955bd668eeff3bc805d201e.r2.cloudflarestorage.com
# Do NOT use that host for <img>: set CLOUDFLARE_R2_ACCOUNT_ID to the same hex id and optionally
# CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=
# Browser-safe public base (custom domain or *.r2.dev bucket URL, no trailing slash) — REQUIRED for previews:
# CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# or https://cdn.flagswing.com
#
# Legacy Vercel Blob façade (only if R2_PUBLIC_URL is unset and Blob still serves bytes):
# BLOB_PUBLIC_BASE_URL=https://xxxx.public.blob.vercel-storage.com

# --- Public site / SEO (frontend) ---
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# Public contact email for mailto links, footers, and legal pages (optional; falls back to a visible placeholder)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com

# Server-side API base (preferred on Vercel; not exposed to the browser)
# Example (Railway): https://your-service.up.railway.app/api
# Example (custom domain): https://api.yourdomain.com/api
# REQUIRED for email/password register & login, Clerk billing bridge, and Paddle proxies.
# Must be reachable from Vercel — never http://localhost in production.
API_URL=

# Public API base (fallback if API_URL unset; used by browser + server — set when admin/marketplace axios hits backend directly)
# Production example: NEXT_PUBLIC_API_URL=https://YOUR-RAILWAY-BACKEND-URL/api (must match the backend mount path `/api`).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: HS256 secret matching backend `JWT_SECRET` so access cookies can be verified (legacy JWT path).
# Middleware uses Clerk (`middleware.ts`). Layout/API may still validate via /auth/me.
AUTH_JWT_SECRET=

# Clerk users: optional link to backend JWT cookies (dashboard purchases). Paddle checkout uses Clerk session tokens directly.
# Must match backend INTERNAL_AUTH_BRIDGE_SECRET when set. Never expose to the browser — server-only on Next.
INTERNAL_AUTH_BRIDGE_SECRET=

# Optional cookie names (defaults: fs_access, fs_refresh)
# AUTH_COOKIE_ACCESS=fs_access
# AUTH_COOKIE_REFRESH=fs_refresh

# Optional: override cookie max-age in seconds (defaults: access 900, refresh 30d)
# AUTH_ACCESS_MAX_AGE_SECONDS=900
# AUTH_REFRESH_MAX_AGE_SECONDS=2592000

# --- Cloudflare R2 (public previews — safe in browser) ---
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://your-public-r2-or-cdn.example
# NEXT_PUBLIC_R2_PUBLIC_BUCKET_NAME=my-public-previews

# Private R2 credentials belong on the SERVER ONLY (backend or Next Route Handler), e.g.:
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Paid-download bypass emails (comma-separated). Default at build mirrors next.config fallback owner inbox.
# NOT the same as ADMIN_EMAIL — keep this narrow (e.g. your operator Gmail only).
# MARKETPLACE_OWNER_DOWNLOAD_EMAILS=

# --- Billing -----------------------------------------------------------------
# Billing runs on the backend (Paddle Billing). These frontend routes proxy to API_URL:
#   /api/billing/checkout, /portal, /subscription, /orders, etc.
#
# Configure on the BACKEND (.env there):
#   PADDLE_API_KEY, PADDLE_WEBHOOK_SECRET, PADDLE_PRICE_MAP_JSON,
#   PADDLE_CHECKOUT_SUCCESS_URL (optional)
#
# Webhook URL (register in Paddle Dashboard → Notifications):
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/paddle
