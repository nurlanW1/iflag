# Admin allow-list: comma/semicolon/newline-separated Clerk emails (any linked address may access /admin).
# If unset, a built-in fallback owner address is used — set explicitly in production to override.
# Mirrors into NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST (+ first entry as NEXT_PUBLIC_ADMIN_EMAIL) in next.config.mjs.
ADMIN_EMAIL=

# Flagswing gallery: when true (default), `free` tier files require sign-in via `/api/download/[fileId]` (no plan).
# Set to false to allow anonymous download of `free`-tier DB files (still not recommended).
# FLAGSWING_FREE_DOWNLOAD_REQUIRES_SIGNIN=true
#
# After deploy, apply `apps/backend/src/db/migrations/neon_002_user_subscriptions_clerk.sql` on Neon for paid plans.

# Optional overrides (otherwise derived from ADMIN_EMAIL at build).
# NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=a@x.com,b@y.com
# NEXT_PUBLIC_ADMIN_EMAIL=

# Postgres (same Neon DATABASE_URL — required for `/api/admin/flag-files/upload` row insert)
DATABASE_URL=

# Vercel Blob upload token (never NEXT_PUBLIC_*)
BLOB_READ_WRITE_TOKEN=

# --- Public site / SEO (frontend) ---
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# Public contact email for mailto links, footers, and legal pages (optional; falls back to a visible placeholder)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com

# Server-side API base (preferred on Vercel; not exposed to the browser)
# Example: https://api.yourdomain.com/api
API_URL=

# Public API base (fallback if API_URL unset; used by browser + server)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: HS256 secret matching backend `JWT_SECRET` so access cookies can be verified (legacy JWT path).
# Middleware uses Clerk (`middleware.ts`). Layout/API may still validate via /auth/me.
AUTH_JWT_SECRET=

# Optional cookie names (defaults: fs_access, fs_refresh)
# AUTH_COOKIE_ACCESS=fs_access
# AUTH_COOKIE_REFRESH=fs_refresh

# Optional: override cookie max-age in seconds (defaults: access 900, refresh 30d)
# AUTH_ACCESS_MAX_AGE_SECONDS=900
# AUTH_REFRESH_MAX_AGE_SECONDS=2592000

# --- Cloudflare R2 (public previews — safe in browser) ---
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://your-public-r2-or-cdn.example
# NEXT_PUBLIC_R2_PUBLIC_BUCKET_NAME=my-public-previews

# Private R2 credentials belong on the SERVER ONLY (backend or Next Route Handler), e.g.:
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Pro file downloads: comma-separated emails that skip purchase/subscription (default: nurlanrahmonqulov@gmail.com).
# MARKETPLACE_OWNER_DOWNLOAD_EMAILS=

# --- Billing -----------------------------------------------------------------
# All billing now flows through the backend. The frontend's /api/billing/* routes
# are thin proxies that forward to API_URL + /billing/*. Provider (Paddle / LS)
# is selected on the backend via BILLING_PROVIDER env.
#
# Configure these on the BACKEND, not here:
#   PADDLE_API_KEY, PADDLE_WEBHOOK_SECRET, PADDLE_PRICE_MAP_JSON,
#   PADDLE_CHECKOUT_SUCCESS_URL, BILLING_PROVIDER=paddle
#
# Webhook URLs to register in Paddle / Lemon Squeezy:
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/paddle
#   https://api.YOUR_DOMAIN.com/api/billing/webhook/lemonsqueezy (legacy)

# --- Lemon Squeezy (LEGACY — only needed if the old /api/billing/lemonsqueezy
#                    Next.js routes are still in use; new flows use backend.) -
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_SIGNING_SECRET=
# LEMONSQUEEZY_VARIANT_MAP_JSON={"oneTimeByProductSlug":{"united-states-standard":"VARIANT_ID"},"subscriptionByPlanSlug":{"pro-monthly":"VARIANT_ID"}}
# LEMONSQUEEZY_CHECKOUT_SUCCESS_URL=https://yourdomain.com/dashboard/purchases
# LEMONSQUEEZY_TEST_MODE=false
